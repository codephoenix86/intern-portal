# -----------------------------------------------------------------------------
# Career Navigator - Server Environment Variables (Template)
# -----------------------------------------------------------------------------
# Usage:
# 1) Copy this file to `.env`
# 2) Fill in required values
# 3) NEVER commit your real `.env` (secrets) to git
#
# Notes:
# - Keep values unquoted unless they contain spaces.
# - Time formats like `15m`, `7d` are app-specific (match what your code expects).
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port for the backend API server.
PORT=5000

# Runtime environment: development | test | production
NODE_ENV=development

# Base URL of the frontend (used for CORS, redirects, links, etc.)
CLIENT_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Database (MongoDB)
# -----------------------------------------------------------------------------
# Example (local):
# MONGODB_URI=mongodb://127.0.0.1:27017/career_navigator
#
# Example (MongoDB Atlas):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=

# -----------------------------------------------------------------------------
# Auth (JWT)
# -----------------------------------------------------------------------------
# Generate long random secrets for production (32+ bytes).
# Different secrets are recommended for access vs refresh tokens.
ACCESS_TOKEN_SECRET=change-me-access-token-secret
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret

# Token lifetimes (examples: 15m, 7d)
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# OAuth (Google / GitHub) - Optional
# -----------------------------------------------------------------------------
# Create OAuth credentials in the provider console and set redirect URI(s)
# to match your server route(s).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match your backend callback route exactly.
# Example: http://localhost:5000/api/auth/google/callback
GOOGLE_REDIRECT_URI=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Media Uploads (Cloudinary) - Optional
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend) - Optional
# -----------------------------------------------------------------------------
RESEND_API_KEY=